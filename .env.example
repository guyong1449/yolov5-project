# ============================================================================
# YOLOv5 项目环境配置模板
# ============================================================================
# 复制本文件为 .env，然后修改为本机实际路径。
# .env 已加入 .gitignore，不会被提交；本文件作为仓库中的参考模板。
#
# 使用方法：
#   1. cp .env.example .env
#   2. 修改 .env 中的路径为本机实际值
#   3. 运行以下命令同步 dataAirVis.yaml：
#      python -c "from utils.env_config import sync_data_yaml; sync_data_yaml()"
#
# Python 加载方式：utils/env_config.py 在 import 时自动加载 .env
# Shell 加载方式：  source .env（benchmark 脚本会自动加载）
# 环境变量优先级：  系统环境变量 > .env 文件 > 代码中的默认值
# ============================================================================

# --- 数据路径 -----------------------------------------------------------------
# 所有项目数据的根目录（视频、图片、标注文件等）
# YOLO_DATA_ROOT=

# 数据集目录（包含 train.txt / val.txt 图片列表文件）
# 训练和验证时 YOLOv5 通过此目录下的 txt 文件找到图片
# YOLO_DATASET_DIR=

# 推理用视频/图片源目录
# YOLO_VIDEO_DIR=

# FiftyOne 去重报告输出目录（当前未使用）
# YOLO_DEDUP_REPORTS_DIR=

# --- 输出路径 -----------------------------------------------------------------
# 训练/检测/验证结果的根输出目录
# YOLO_OUTPUT_ROOT=

# --- 模型 / 权重 -------------------------------------------------------------
# 默认模型权重文件路径（相对于项目根目录，或绝对路径）
# YOLO_WEIGHTS=checkpoint/yolov5_best.pt

# --- 设备 --------------------------------------------------------------------
# 计算设备：cpu / 0 / 0,1 / npu:0 / npu:0,1,2,3 等
# YOLO_DEVICE=npu:0,1,2,3

# --- GUI 面板 -----------------------------------------------------------------
# YOLO_GUI_HOST=127.0.0.1
# YOLO_GUI_PORT=8752

# --- 训练配置 -----------------------------------------------------------------
# 超参数文件路径（相对于项目根目录）
# YOLO_HYP_FILE=runs/train/test1_stride10_sgd_70e3/hyp.yaml

# 数据集配置 YAML（相对于项目根目录）
# YOLO_DATA_YAML=data/dataAirVis.yaml

# DDP 分布式训练用的数据集 YAML（绝对路径）
# YOLO_DDP_DATA_YAML=

# --- 分布式训练 ---------------------------------------------------------------
# DDP 通信主节点端口，多个任务同时运行时需使用不同端口
# YOLO_MASTER_PORT=29501

# --- Conda 环境 --------------------------------------------------------------
# 自定义 Python 解释器路径，例如 /root/miniconda3/envs/yolo/bin/python
# YOLO_PYTHON_BIN=
